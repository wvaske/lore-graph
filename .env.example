# Neo4j (local dev via docker-compose)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me

# Extraction LLM (swap for local tooling if preferred)
ANTHROPIC_API_KEY=sk-ant-...
